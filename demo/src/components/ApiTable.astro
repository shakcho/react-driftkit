---
import type { ApiRow } from '../data/types';

export interface Props {
  rows: ApiRow[];
  footnoteHtml?: string;
}

const { rows, footnoteHtml } = Astro.props;
---

<div class="table-wrap">
  <table class="api-table">
    <thead>
      <tr>
        <th>Prop</th>
        <th>Type</th>
        <th>Default</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          <td><code>{row.prop}</code></td>
          <td set:html={row.typeHtml} />
          <td set:html={row.defaultHtml} />
          <td set:html={row.descriptionHtml} />
        </tr>
      ))}
    </tbody>
  </table>
</div>
{footnoteHtml && (
  <p class="api-footnote" set:html={footnoteHtml} />
)}
