{
  "name": "react-drift",
  "version": "0.1.0",
  "description": "A draggable, floating widget wrapper for React — snap to corners or drag anywhere",
  "type": "module",
  "main": "dist/react-drift.cjs",
  "module": "dist/react-drift.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-drift.js",
      "require": "./dist/react-drift.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config demo/vite.config.ts",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "prismjs": "^1.30.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "keywords": [
    "react",
    "draggable",
    "movable",
    "widget",
    "drift",
    "floating"
  ],
  "license": "MIT"
}
