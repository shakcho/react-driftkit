{
  "name": "react-driftkit",
  "version": "0.1.2",
  "description": "A draggable, floating widget wrapper for React — snap to corners or drag anywhere",
  "type": "module",
  "main": "dist/react-driftkit.cjs",
  "module": "dist/react-driftkit.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-driftkit.js",
      "require": "./dist/react-driftkit.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:demo": "vite build --config demo/vite.config.ts",
    "prepublishOnly": "npm run build",
    "preview": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shakcho/react-drift.git"
  },
  "homepage": "https://github.com/shakcho/react-drift#readme",
  "author": "Sakti Kumar Chourasia",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "prismjs": "^1.30.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "keywords": [
    "react",
    "draggable",
    "movable",
    "widget",
    "driftkit",
    "floating"
  ],
  "license": "MIT"
}
